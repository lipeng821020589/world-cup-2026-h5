/* pages/index/index.wxss */
.countdown-card {
  background: linear-gradient(135deg, #1a472a 0%, #2e7d32 100%);
  color: #fff;
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  text-align: center;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(26, 71, 42, 0.3);
}

.cd-label {
  font-size: 28rpx;
  opacity: 0.9;
  margin-bottom: 16rpx;
}

.cd-time {
  display: flex;
  justify-content: center;
  align-items: baseline;
  margin-bottom: 12rpx;
}

.cd-num {
  font-size: 72rpx;
  font-weight: 700;
  font-family: 'Helvetica Neue', monospace;
  margin: 0 8rpx;
}

.cd-unit {
  font-size: 28rpx;
  opacity: 0.9;
  margin-right: 24rpx;
}

.cd-extra {
  font-size: 24rpx;
  opacity: 0.7;
}

.match {
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 12rpx;
}

.match-time {
  font-size: 24rpx;
  color: #1a472a;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.match-teams {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 6rpx;
}

.match-stage {
  font-size: 24rpx;
  color: #888;
}

.prob-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.prob-row:last-child { border-bottom: none; }

.prob-name {
  width: 240rpx;
  display: flex;
  align-items: center;
}

.flag {
  font-size: 32rpx;
  margin-right: 8rpx;
}

.name {
  font-size: 28rpx;
  font-weight: 500;
}

.prob-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.prob-pct {
  font-size: 24rpx;
  font-weight: 600;
  color: #1a472a;
  width: 80rpx;
  text-align: right;
}

.death-group {
  background: #fff5f5;
  border-left: 6rpx solid #c62828;
  padding: 16rpx 20rpx;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
}

.dg-letter {
  font-size: 30rpx;
  font-weight: 700;
  color: #c62828;
  margin-bottom: 6rpx;
}

.dg-reason {
  font-size: 26rpx;
  color: #555;
  margin-bottom: 6rpx;
}
