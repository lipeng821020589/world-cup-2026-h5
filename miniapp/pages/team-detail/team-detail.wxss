/* pages/team-detail/team-detail.wxss */
.header {
  background: linear-gradient(135deg, #1a472a 0%, #2e7d32 100%);
  color: #fff;
  text-align: center;
  padding: 40rpx 24rpx;
}

.big-flag {
  font-size: 100rpx;
  margin-bottom: 16rpx;
}

.name {
  font-size: 44rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.meta-row {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.score-badge {
  display: inline-block;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 600;
}

.rank {
  font-size: 26rpx;
  opacity: 0.9;
}

.player-row {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.player-row:last-child { border-bottom: none; }

.player-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 6rpx;
}

.p-name {
  font-size: 30rpx;
  font-weight: 600;
}

.p-key {
  font-size: 24rpx;
}

.p-meta {
  font-size: 24rpx;
  color: #888;
}

.p-notes {
  font-size: 24rpx;
  color: #555;
  margin-top: 4rpx;
}

.opp-row {
  display: flex;
  align-items: center;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
  background: #f8f8f8;
}

.opp-row.self {
  background: #e8f5e9;
  border: 2rpx solid #1a472a;
  font-weight: 600;
}

.opp-rank {
  width: 40rpx;
  color: #1a472a;
  font-weight: 700;
}

.flag {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.opp-name {
  flex: 1;
}

.opp-score {
  font-family: monospace;
  color: #888;
}

.debut-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.debut-list text {
  background: #fff3e0;
  color: #e65100;
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 24rpx;
}
