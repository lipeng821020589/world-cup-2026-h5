/* pages/odds/odds.wxss */
.prob-row {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.prob-row:last-child { border-bottom: none; }

.flag {
  font-size: 30rpx;
  margin-right: 8rpx;
}

.prob-name {
  width: 200rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.prob-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.prob-pct {
  width: 100rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 600;
  color: #1a472a;
  font-family: monospace;
}

.odds-row {
  display: flex;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.odds-row:last-child { border-bottom: none; }

.odds-team {
  flex: 1;
  display: flex;
  align-items: center;
}

.team-name {
  font-size: 28rpx;
  font-weight: 500;
}

.odds-numbers {
  width: 160rpx;
  text-align: right;
  margin-right: 16rpx;
}

.dec {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #1a472a;
  font-family: monospace;
}

.american {
  display: block;
  font-size: 22rpx;
  color: #888;
  font-family: monospace;
}

.value-cell {
  width: 100rpx;
  text-align: right;
}

.value-mark {
  font-size: 24rpx;
  margin-right: 4rpx;
}

.value-num {
  font-size: 26rpx;
  font-weight: 600;
  font-family: monospace;
}

.legend {
  margin-top: 16rpx;
  font-size: 22rpx;
  text-align: center;
}
