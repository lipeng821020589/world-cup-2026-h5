/* app.wxss - 全局样式 */
page {
  background: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 28rpx;
  color: #222;
  line-height: 1.6;
}

.container {
  padding: 20rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
  color: #1a472a;
  display: flex;
  align-items: center;
}

.card-title-icon {
  margin-right: 12rpx;
}

.row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.row:last-child {
  border-bottom: none;
}

.tag {
  display: inline-block;
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  margin-right: 8rpx;
}

.tag-t1 { background: #fff3e0; color: #e65100; }
.tag-t2 { background: #e3f2fd; color: #1565c0; }
.tag-t3 { background: #e8f5e9; color: #2e7d32; }
.tag-t4 { background: #f3e5f5; color: #6a1b9a; }
.tag-qual { background: #c8e6c9; color: #1b5e20; }
.tag-elim { background: #ffcdd2; color: #b71c1c; }
.tag-death { background: #ffebee; color: #c62828; font-weight: 600; }

.btn {
  display: inline-block;
  background: #1a472a;
  color: #fff;
  padding: 12rpx 32rpx;
  border-radius: 32rpx;
  font-size: 26rpx;
  text-align: center;
  margin-top: 16rpx;
}

.text-muted {
  color: #888;
  font-size: 24rpx;
}

.bar {
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin: 8rpx 0;
}

.bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #1a472a, #2e7d32);
  border-radius: 8rpx;
}
